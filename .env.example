# Research Environment API — environment configuration template.
#
# Copy this file to `.env` and fill in real values for your environment:
#     cp .env.example .env
#
# `.env` is gitignored and must never be committed. Values below are
# placeholders only — replace them with values for your own GCP project.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
FLASK_APP="research_environment_api.wsgi:app"
# APP_ENV selects the config profile: "development" or "production".
APP_ENV=development

# ---------------------------------------------------------------------------
# GCP core
# ---------------------------------------------------------------------------
PROJECT_ID=your-gcp-project-id
# Path to the GCP service-account key JSON used by the API.
SERVICE_ACCOUNT_CREDENTIALS_PATH=/path/to/service-account-credentials.json
# Google Workspace / Cloud Identity domain used to build group and user emails.
ORGANIZATION_DOMAIN=example.org
# Optional — required only by org-level IAM and identity operations.
ORGANIZATION_ID=
CUSTOMER_ID=
BILLING_ACCOUNT_CREATOR_GROUP_ID=your-billing-creator-group-id
VPC_SECURE_PERIMETER_NAME=your-vpc-service-controls-perimeter
CLOUD_BUILD_SERVICE_ACCOUNT_NAME=projects/your-gcp-project-id/serviceAccounts/builder@your-gcp-project-id.iam.gserviceaccount.com
DATA_PROJECT_NAME=your-data-project
NETWORK_NAME=your-vpc-network
SHARING_FOLDER_ID=000000000000
WORKBENCHES_PARENT_PROJECT_ID=000000000000
GCP_SIGNED_URL_EXPIRATION_TIME=600
GCP_CORS_ALLOWED_ORIGINS="https://your-frontend.example.org"
# Secret Manager resource holding the GitHub SSH key used to clone the
# workbench-provisioning Terraform repo.
GITHUB_SSH_KEY_KSM_ID="projects/000000000000/secrets/github-ssh-key/versions/1"
MONITORING_CSV_EXPORTS_ROOT_BUCKET=your-monitoring-exports-bucket

# ---------------------------------------------------------------------------
# Workbench-provisioning Terraform (cloned and run via Cloud Build)
# ---------------------------------------------------------------------------
TERRAFORM_REPO_NAME=your-org/terraform-workbench-creation
TERRAFORM_BRANCH_NAME=main

# ---------------------------------------------------------------------------
# Workbench images, startup scripts and RStudio networking
# ---------------------------------------------------------------------------
JUPYTER_STARTUP_SCRIPT=jupyter_startup_script
RSTUDIO_STARTUP_SCRIPT=rstudio_startup_script
RSTUDIO_IMAGE_URL=projects/your-gcp-project-id/global/images/rstudio-server-image
RSTUDIO_DNS_PROJECT=your-dns-project
RSTUDIO_DNS_ZONE=your-dns-zone
RSTUDIO_DOMAIN_NAME=rstudio.example.org.
# Secret Manager secret id holding the RStudio TLS certificate/key.
RSTUDIO_CERTIFICATE_SECRET_ID=your-rstudio-cert-secret-id

# ---------------------------------------------------------------------------
# Admin panel
# ---------------------------------------------------------------------------
ADMIN_PANEL_USERNAME=change-me
ADMIN_PANEL_PASSWORD=change-me
ADMIN_PANEL_CACHE_TTL=300

# ---------------------------------------------------------------------------
# Database
#   development: set DATABASE_URL
#   production:  set DATABASE_NAME + CLOUD_SQL_INSTANCE_CONNECTION_NAME
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/research_environment_api_dev
# DATABASE_NAME=research_environment_api
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-gcp-project-id:region:instance

# ---------------------------------------------------------------------------
# Celery / cache
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
CACHE_TYPE=SimpleCache
