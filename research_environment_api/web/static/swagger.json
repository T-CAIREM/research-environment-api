Request": {"type": "object", "properties": {"workspace_project_id": {"type": "string"}, "workbench_type": {"enum": ["jupyter", "rstudio"]}, "workbench_resource_id": {"type": "string"}, "user_email": {"type": "string"}}, "required": ["user_email", "workbench_resource_id", "workbench_type", "workspace_project_id"]}, "Workflow": {"type": "object", "properties": {"id": {"type": "string"}, "error": {"type": "string"}, "build_type": {"enum": ["workspace_creation", "workspace_deletion", "jupyter_creation", "jupyter_destroy", "rstudio_creation", "jupyter_creation_retry", "jupyter_stop", "jupyter_start", "jupyter_update"]}, "status": {"enum": ["in_progress", "failure", "success"]}}, "required": ["build_type", "id", "status"]}}}}