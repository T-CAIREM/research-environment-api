ench_resource_id", "workbench_type", "workspace_project_id"]}, "WorkbenchDestroyRequest": {"type": "object", "properties": {"user_email": {"type": "string"}, "workspace_project_id": {"type": "string"}, "workbench_type": {"enum": ["jupyter", "rstudio"]}, "workbench_resource_id": {"type": "string"}}, "required": ["user_email", "workbench_resource_id", "workbench_type", "workspace_project_id"]}}}}